# Godot 4+ specific ignores
.godot/
.nomedia

# Godot-specific ignores
.import/
export.cfg
export_credentials.cfg

# Imported translations (automatically generated from CSV files)
*.translation

# Mono-specific ignores
.mono/
data_*/
mono_crash.*.json

# macOS system files
.DS_Store

# Go
backend/internal/pb/*.pb.go
# Stray binaries from `go build ./cmd/<name>` (no -o) — drops at module root.
# The Makefile builds into dist/bin/ (covered by dist/ above); these cover
# the case where someone builds directly in backend/.
backend/pusher
backend/worldsim
backend/ext-demo
backend/ext-walls
backend/ext-props
backend/ext-av
backend/ext-rec
backend/audit
backend/admin

# Node
node_modules/
frontend/src/proto/

# Build outputs (binaries + web assets)
/dist/

# Docker
.docker/

# Local env files (e.g. PUBLIC_HOST, LIVEKIT_NODE_IP)
.env
*.env

# PocketBase
pb_data/

# Tileset art packs (large, third-party — not committed)
assets/moderninteriors-win/
assets/Modern_Office_Revamped_v1/

# Generated copies of root authoritative asset directories
frontend/public/assets/
frontend/public/sprites/
maps/main.tiled-session
